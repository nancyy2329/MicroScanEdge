# Copy this file to .env and fill in real values before running the server.
# src/config/env.js validates that every "required" variable below is
# present and will refuse to start if any are missing.

# ── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Neo4j AuraDB (required) ─────────────────────────────────────────────
NEO4J_URI=neo4j+s://82ad9d5b.databases.neo4j.io
NEO4J_USERNAME=82ad9d5b
NEO4J_PASSWORD=z0v1fZLu3QfTL9QwFuuNKV4lgP8Aq5Aq0fZ4VG6xeiY

# ── Sarvam AI (required) ────────────────────────────────────────────────
SARVAM_API_KEY=sk_zfzfa5hs_741JySev77eXWGrNkZL46pF8
SARVAM_API_BASE_URL=https://api.sarvam.ai
SARVAM_MODEL=sarvam-30b

# ── Access control (optional but strongly recommended) ─────────────────
# If unset, the analysis endpoint has no access-control gate at all.
APP_ACCESS_KEY=

# ── Uploads ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for local dev.
ALLOWED_ORIGINS=*

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ── E2E tests (tests/e2e-test.js) ───────────────────────────────────────
# Base URL the e2e suite hits. Defaults to http://localhost:$PORT.
E2E_BASE_URL=
