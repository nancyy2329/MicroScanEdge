{
  "info": {
    "name": "MicroScan Edge API",
    "description": "Backend API for MicroScan Edge — image-based water contamination analysis. Import this collection, set `baseUrl` to your running server (default http://localhost:4000), and for the two \"Create Analysis\" requests, attach sample-water-image.jpg (shipped alongside this collection) or any JPEG/PNG/WEBP under the request's image field.\n\nRun the \"Happy Path\" folder top-to-bottom (or use Collection Runner) to exercise the full create -> list -> get-by-id flow — the Create Analysis request saves its returned id into the {{analysisId}} collection variable, which Get Analysis by ID then uses automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "analysisId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "Confirms the server is up. Not the formal /api/v1/health from the architecture doc (that endpoint isn't built yet) — this is the inline check from app.js."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body reports ok status', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.service).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "1. Create Analysis",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "REQUIRED. Attach sample-water-image.jpg (shipped alongside this collection) or your own JPEG/PNG/WEBP."
                },
                { "key": "language", "value": "English", "type": "text", "description": "Optional, defaults to English if omitted." },
                { "key": "source", "value": "CAMERA", "type": "text", "description": "Optional: CAMERA or GALLERY, defaults to CAMERA." }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/v1/analysis", "host": ["{{baseUrl}}"], "path": ["api", "v1", "analysis"] },
            "description": "Runs the full pipeline: feature extraction -> scoring -> Sarvam explanation -> save to Neo4j -> respond."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('success is true', () => pm.expect(body.success).to.be.true);",
                  "pm.test('has an id', () => pm.expect(body.data.id).to.be.a('string').and.not.empty);",
                  "pm.test('contaminationScore is 0-100', () => {",
                  "  pm.expect(body.data.contaminationScore).to.be.a('number');",
                  "  pm.expect(body.data.contaminationScore).to.be.at.least(0).and.at.most(100);",
                  "});",
                  "pm.test('riskLevel is a known band', () => {",
                  "  pm.expect(['LOW', 'MODERATE', 'HIGH', 'CRITICAL']).to.include(body.data.riskLevel);",
                  "});",
                  "pm.test('features are present', () => {",
                  "  pm.expect(body.data.features).to.have.property('brightness');",
                  "  pm.expect(body.data.features).to.have.property('edgeDensity');",
                  "  pm.expect(body.data.features).to.have.property('particleEstimate');",
                  "  pm.expect(body.data.features.colorHistogram).to.have.property('r').that.is.an('array');",
                  "});",
                  "pm.test('explanation is present', () => {",
                  "  pm.expect(body.data.explanation).to.have.property('text').that.is.a('string').and.not.empty;",
                  "});",
                  "pm.test('image url points at /uploads/', () => {",
                  "  pm.expect(body.data.image.url).to.include('/uploads/');",
                  "});",
                  "",
                  "// Saved for the next two requests in this folder.",
                  "pm.collectionVariables.set('analysisId', body.data.id);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "2. Get Analysis by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/{{analysisId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "{{analysisId}}"]
            },
            "description": "Uses the {{analysisId}} saved by the previous request — run 'Create Analysis' first if this is empty."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('returns the same analysis we just created', () => {",
                  "  pm.expect(body.data.id).to.eql(pm.collectionVariables.get('analysisId'));",
                  "});",
                  "pm.test('full detail includes explanation and features', () => {",
                  "  pm.expect(body.data).to.have.property('explanation');",
                  "  pm.expect(body.data).to.have.property('features');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "3. List History",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/history", "host": ["{{baseUrl}}"], "path": ["api", "v1", "history"] },
            "description": "Should include the analysis created in step 1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('items is an array', () => pm.expect(body.data.items).to.be.an('array'));",
                  "pm.test('includes the analysis from step 1', () => {",
                  "  const ids = body.data.items.map((item) => item.id);",
                  "  pm.expect(ids).to.include(pm.collectionVariables.get('analysisId'));",
                  "});",
                  "pm.test('hasMore field is a boolean', () => pm.expect(body.data.hasMore).to.be.a('boolean'));"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "History Filters",
      "item": [
        {
          "name": "List History (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/history?limit=2&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "history"],
              "query": [{ "key": "limit", "value": "2" }, { "key": "offset", "value": "0" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns at most 2 items', () => {",
                  "  pm.expect(pm.response.json().data.items.length).to.be.at.most(2);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "List History (min score filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/history?minScore=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "history"],
              "query": [{ "key": "minScore", "value": "50" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('every returned item scores >= 50', () => {",
                  "  const items = pm.response.json().data.items;",
                  "  items.forEach((item) => pm.expect(item.contaminationScore).to.be.at.least(50));",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Create Analysis — missing image",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "formdata", "formdata": [{ "key": "language", "value": "English", "type": "text" }] },
            "url": { "raw": "{{baseUrl}}/api/v1/analysis", "host": ["{{baseUrl}}"], "path": ["api", "v1", "analysis"] },
            "description": "No image field at all — should be rejected by upload.middleware.js before the controller ever runs."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('code is NO_IMAGE', () => {",
                  "  pm.expect(pm.response.json().error.code).to.eql('NO_IMAGE');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Create Analysis — invalid source value",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": [], "description": "Attach sample-water-image.jpg" },
                { "key": "source", "value": "SATELLITE", "type": "text", "description": "Invalid on purpose — only CAMERA/GALLERY are accepted." }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/v1/analysis", "host": ["{{baseUrl}}"], "path": ["api", "v1", "analysis"] },
            "description": "Demonstrates validate.middleware.js rejecting a bad enum value with a 400, and that the resulting orphaned upload gets cleaned up automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('code is VALIDATION_ERROR', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error.code).to.eql('VALIDATION_ERROR');",
                  "  pm.expect(body.error.details[0].field).to.eql('source');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Analysis — not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analysis/does-not-exist-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analysis", "does-not-exist-id"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('code is NOT_FOUND', () => {",
                  "  pm.expect(pm.response.json().error.code).to.eql('NOT_FOUND');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "List History — invalid limit",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/history?limit=9999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "history"],
              "query": [{ "key": "limit", "value": "9999" }]
            },
            "description": "limit is capped at 100 by historyQuerySchema — anything higher should be rejected, not silently clamped."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('code is VALIDATION_ERROR', () => {",
                  "  pm.expect(pm.response.json().error.code).to.eql('VALIDATION_ERROR');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    }
  ]
}
